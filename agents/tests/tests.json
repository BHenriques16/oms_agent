{
  "oms_presentation_demo": {
    "metadata": {
      "description": "Testing guide for the agents",
      "target_models": ["Local LLM"]
    },
    "agents": [
      {
        "agent_name": "Demographics Specialist",
        "endpoint": "/agent/demographics",
        "queries": [
          {
            "scenario": "Comprehensive Profile Extraction",
            "query": "Can you give me the full demographic profile of offender ID 5?"
          }
        ]
      },
      {
        "agent_name": "Incarcerations Specialist",
        "endpoint": "/agent/incarcerations",
        "queries": [
          {
            "scenario": "Sentence Summary",
            "query": "Give me all incarcerations details for offender ID 8."
          }
        ]
      },
      {
        "agent_name": "Criminal History Specialist",
        "endpoint": "/agent/criminal-history",
        "queries": [
          {
            "scenario": "Full Background Check",
            "query": "Summarize the prior criminal history for offender ID 2."
          }
        ]
      },
      {
        "agent_name": "Supervision Specialist",
        "endpoint": "/agent/supervision",
        "queries": [
          {
            "scenario": "Conduct Audit",
            "query": "What is the overall supervision conduct for incarceration ID 10?"
          }
        ]
      },
      {
        "agent_name": "Outcomes Specialist",
        "endpoint": "/agent/outcomes",
        "queries": [
          {
            "scenario": "Post-Release Summary",
            "query": "What are the post-release outcomes for offender ID 9?"
          }
        ]
      },
      {
        "agent_name": "Statistical Count Specialist",
        "endpoint": "/agent/count",
        "notes": "Stress-test environment for A/B Testing between Local and Server LLMs.",
        "queries": [
          {
            "scenario": "Categorical Enum Mapping",
            "query": "How many offenders have a high school diploma?"
          },
          {
            "scenario": "Multi-Parameter Stress Test",
            "query": "How many Black offenders are not gang affiliated and have Some College education?"
          }
        ]
      },
      {
        "agent_name": "Hallucination & Security Auditing",
        "endpoint": "Various",
        "notes": "Queries designed specifically to break the system or test schema resilience.",
        "queries": [
          {
            "scenario": "ID Out of Bounds",
            "endpoint": "/agent/demographics",
            "query": "What is the race of offender ID 99?"          
          },
          {
            "scenario": "Unsupported Parameter Injection",
            "endpoint": "/agent/demographics",
            "query": "What offenders have blue eyes?"          
          }
        ]
      }
    ]
  }
}